<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.seuoj.seuojbackend.mapper.UserRoleRelMapper">
    <select id="getRoleCodesByUserId" resultType="java.lang.String">
        SELECT r.role_code
        FROM user_role_rel urr
        JOIN user_role r ON urr.role_id = r.id
        WHERE urr.user_id = #{userId}
          AND urr.is_del = 0
          AND r.is_del = 0
    </select>

    <select id="selectRoleCodesByUserIds" resultType="com.seuoj.seuojbackend.vo.common.UserRoleRowVO">
        SELECT urr.user_id AS user_id,
               r.role_code AS role_code
        FROM user_role_rel urr
        INNER JOIN user_role r ON r.id = urr.role_id
        WHERE urr.is_del = 0
          AND r.is_del = 0
          <if test="userIds != null and userIds.size() > 0">
              AND urr.user_id IN
              <foreach collection="userIds" item="userId" open="(" separator="," close=")">
                  #{userId}
              </foreach>
          </if>
          <if test="visibleRoleCodes != null and visibleRoleCodes.size() > 0">
              AND r.role_code IN
              <foreach collection="visibleRoleCodes" item="roleCode" open="(" separator="," close=")">
                  #{roleCode}
              </foreach>
          </if>
    </select>
</mapper>