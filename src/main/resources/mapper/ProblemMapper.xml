<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.seuoj.seuojbackend.mapper.ProblemMapper">

    <update id="atomicallyIncreaseTotalSubmissionCount">
        UPDATE problem
        SET total_submit = total_submit + 1
        WHERE id = #{problemId}
    </update>

    <update id="atomicallyIncreaseTotalAcceptCount">
        UPDATE problem
        SET total_accept = total_accept + 1
        WHERE id = #{problemId}
    </update>

    <resultMap id="ProblemDetailMap" type="com.seuoj.seuojbackend.vo.problem.ProblemDetailVO">
        <id column="pid" property="pid"/>
        <result column="title" property="title"/>
        <result column="total_submit" property="totalSubmit"/>
        <result column="total_accept" property="totalAccept"/>
    </resultMap>

    <select id="getProblemDetail" resultMap="ProblemDetailMap">
        SELECT p.pid,
               p.title,
               p.total_submit,
               p.total_accept
        FROM problem p
        WHERE p.pid = #{pid}
          AND p.is_del = 0
          AND p.is_public = 1
    </select>

    <select id="getProblemTags" resultType="java.lang.String">
        SELECT t.tag_name
        FROM tag t
                 JOIN problem_tag_rel ptr ON t.id = ptr.tag_id
                 JOIN problem p ON ptr.problem_id = p.id
        WHERE p.pid = #{pid}
          AND p.is_del = 0
          AND p.is_public = 1
          AND t.is_del=0
          AND ptr.is_del=0
    </select>

    <!-- 题目列表项映射 -->
    <resultMap id="ProblemListItemMap" type="com.seuoj.seuojbackend.vo.problem.ProblemListItemVO">
        <id column="pid" property="pid"/>
        <result column="title" property="title"/>
        <result column="total_submit" property="totalSubmit"/>
        <result column="total_accept" property="totalAccept"/>
    </resultMap>

    <sql id="ProblemBaseColumns">
        p.pid,
        p.title,
        p.total_submit,
        p.total_accept
    </sql>

    <sql id="ProblemBaseWhere">
        p.is_del = 0
        AND p.is_public = 1
        <if test="tagIdsSize > 0">
            <!-- 子查询：找出同时包含所有指定标签的题目ID -->
            AND p.id IN (
            SELECT ptr.problem_id
            FROM problem_tag_rel ptr
            WHERE ptr.tag_id IN
            <foreach collection="tagIds" item="tagId" open="(" separator="," close=")">
                #{tagId}
            </foreach>
            AND ptr.is_del = 0
            GROUP BY ptr.problem_id
            HAVING COUNT(DISTINCT ptr.tag_id) = #{tagIdsSize}
            )
        </if>
    </sql>


    <!-- 分页查询题目列表 -->
    <select id="selectProblemPage" resultMap="ProblemListItemMap">
        SELECT
        u.pid,
        u.title,
        u.total_submit,
        u.total_accept,
        MAX(u.score) AS score
        FROM (
        <trim prefixOverrides="UNION ALL">
            <if test="useFulltext">
                UNION ALL
                SELECT
                <include refid="ProblemBaseColumns"/>,
                MATCH(p.title) AGAINST (#{title} IN BOOLEAN MODE) AS score
                FROM problem p
                <where>
                    <include refid="ProblemBaseWhere"/>
                    AND MATCH(p.title) AGAINST (#{title} IN BOOLEAN MODE)
                </where>
            </if>
            <if test="useLikeSingle">
                UNION ALL
                SELECT
                <include refid="ProblemBaseColumns"/>,
                0.1 AS score
                FROM problem p
                <where>
                    <include refid="ProblemBaseWhere"/>
                    AND (
                    <foreach collection="singleTokens" item="tok" separator=" OR ">
                        p.title LIKE CONCAT('%', #{tok}, '%')
                    </foreach>
                    )
                </where>
            </if>
            <if test="useLikeRaw">
                UNION ALL
                SELECT
                <include refid="ProblemBaseColumns"/>,
                0.1 AS score
                FROM problem p
                <where>
                    <include refid="ProblemBaseWhere"/>
                    AND p.title LIKE CONCAT('%', #{titleLike}, '%')
                </where>
            </if>
            <if test="!useFulltext and !useLikeSingle and !useLikeRaw">
                UNION ALL
                SELECT
                <include refid="ProblemBaseColumns"/>,
                0.0 AS score
                FROM problem p
                <where>
                    <include refid="ProblemBaseWhere"/>
                </where>
            </if>
        </trim>
        ) u
        GROUP BY u.pid, u.title, u.total_submit, u.total_accept
        ORDER BY score DESC, u.pid ASC
    </select>

    <!-- 批量获取题目标签 -->
    <resultMap id="ProblemTagResultMap" type="com.seuoj.seuojbackend.mapper.ProblemMapper$ProblemTagResult">
        <result column="pid" property="pid"/>
        <result column="tag_name" property="tagName"/>
    </resultMap>

    <select id="getProblemTagsBatch" resultMap="ProblemTagResultMap">
        SELECT
        p.pid,
        t.tag_name
        FROM tag t
        INNER JOIN problem_tag_rel ptr ON t.id = ptr.tag_id
        INNER JOIN problem p ON ptr.problem_id = p.id
        WHERE p.pid IN
        <foreach collection="pids" item="pid" open="(" separator="," close=")">
            #{pid}
        </foreach>
        AND p.is_del = 0
        AND t.is_del = 0
        AND ptr.is_del = 0
    </select>

</mapper>


