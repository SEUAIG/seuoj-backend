<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.seuoj.seuojbackend.mapper.ProblemMapper">
    <update id="atomicallyIncreaseTotalSubmissionCount">
        UPDATE problem
        SET total_submit = total_submit + 1
        WHERE id = #{problemId}
    </update>
    <update id="atomicallyIncreaseTotalAcceptCount">
        UPDATE problem
        SET total_accept = total_accept + 1
        WHERE id = #{problemId}
    </update>


    <resultMap id="ProblemDetailMap" type="com.seuoj.seuojbackend.vo.problem.ProblemDetailVO">
        <id column="pid" property="pid"/>
        <result column="title" property="title"/>
        <result column="total_submit" property="totalSubmit"/>
        <result column="total_accept" property="totalAccept"/>
    </resultMap>

    <select id="getProblemDetail" resultMap="ProblemDetailMap">
        SELECT p.pid,
               p.title,
               p.total_submit,
               p.total_accept
        FROM problem p
        WHERE p.pid = #{pid}
    </select>

    <select id="getProblemTags" resultType="java.lang.String">
        SELECT t.tag_name
        FROM tag t
                 JOIN problem_tag_rel ptr ON t.id = ptr.tag_id
                 JOIN problem p ON ptr.problem_id = p.id
        WHERE p.pid = #{pid}
    </select>
</mapper>
