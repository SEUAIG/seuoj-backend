<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.seuoj.seuojbackend.mapper.UserInfoMapper">

    <resultMap id="UserPageItemMap" type="com.seuoj.seuojbackend.vo.common.UserPageItemVO">
        <result column="user_id" property="userId"/>
        <result column="username" property="username"/>
        <result column="nickname" property="nickname"/>
        <result column="email" property="email"/>
    </resultMap>

    <select id="selectUserPageBasic" resultMap="UserPageItemMap">
        SELECT ui.id AS user_id,
               ui.username,
               ui.nickname,
               ui.email
        FROM user_info ui
        WHERE ui.is_del = 0
          <if test="roleCodes != null and roleCodes.size() > 0">
              AND EXISTS (
                  SELECT 1
                  FROM user_role_rel urr
                  INNER JOIN user_role ur ON ur.id = urr.role_id AND ur.is_del = 0
                  WHERE urr.user_id = ui.id
                    AND urr.is_del = 0
                    AND ur.role_code IN
                    <foreach collection="roleCodes" item="roleCode" open="(" separator="," close=")">
                        #{roleCode}
                    </foreach>
              )
          </if>
          <if test="username != null and username != ''">
              AND ui.username LIKE CONCAT('%', #{username}, '%')
          </if>
          <if test="email != null and email != ''">
              AND ui.email LIKE CONCAT('%', #{email}, '%')
          </if>
        ORDER BY ui.id DESC
    </select>

</mapper>