<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.seuoj.seuojbackend.mapper.ProblemTagRelMapper">

    <insert id="insertBatch">
        INSERT INTO problem_tag_rel (problem_id, tag_id)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.problemId}, #{item.tagId})
        </foreach>
    </insert>

</mapper>
