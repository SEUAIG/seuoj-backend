spring:
  datasource:
    driver-class-name: com.mysql.cj.jdbc.Driver
    url: jdbc:mysql://localhost:3306/seuoj?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai
    username: ${TEST_DB_USERNAME}
    password: ${TEST_DB_PASSWORD}
  mail:
    host: localhost
    port: 25
    username: test@example.com
    password: test

jwt:
  private-key:
  public-key:
  access-expiration: 86400
  temp-expiration: 300

judge:
  server-url: http://127.0.0.1:19090
  secret: test-judge-secret

storage:
  user-code-storage-path: ./data/user-code-test
  image-path: ./data/images-test
  image-max-file-size: 10485760
  image-allowed-mime-types: image/jpeg,image/png,image/webp,image/gif

mybatis-plus:
  configuration:
    log-impl: org.apache.ibatis.logging.stdout.StdOutImpl
